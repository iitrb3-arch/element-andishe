name: APK (Fdroid arm64 only)

on:
  workflow_dispatch:
  push:

env:
  HS_URL: https://edu97.ir
  GRADLE_OPTS: -Dorg.gradle.jvmargs="-Xmx3072m -Dfile.encoding=UTF-8"
  CI_GRADLE_ARG_PROPERTIES: --stacktrace --max-workers 2 --no-daemon

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-java@v4
        with: { distribution: temurin, java-version: '21' }
      - uses: gradle/actions/setup-gradle@v3

      - name: Set default homeserver
        run: |
          mkdir -p vector-app/src/main/assets
          cat > vector-app/src/main/assets/vector_config.json <<EOF
          { "defaultHomeserverUrl": "${HS_URL}" }
          EOF

      - name: Build Fdroid Debug
        run: ./gradlew :vector-app:assembleFdroidDebug $CI_GRADLE_ARG_PROPERTIES

      - name: List APKs (debug)
        run: ls -R vector-app/build/outputs/apk || true

      # آرتیفکت کم‌حجم (arm64) + فالبک یونیورسال اگر arm64 نبود
      - name: Upload APKs
        uses: actions/upload-artifact@v4
        with:
          name: fdroid-debug
          path: |
            vector-app/build/outputs/apk/**/debug/*arm64-v8a*.apk
            vector-app/build/outputs/apk/**/debug/*universal*.apk
          if-no-files-found: error
