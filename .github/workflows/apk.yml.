name: Build Android APK (Fdroid arm64)

on:
  workflow_dispatch:
  push:
    branches:
      - main
      - develop

env:
  HS_URL: https://edu97.ir
  GRADLE_OPTS: -Dorg.gradle.jvmargs="-Xmx3072m -Dfile.encoding=UTF-8"

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17

      - name: Make Gradle executable
        run: chmod +x ./gradlew

      - name: Configure homeserver
        run: |
          mkdir -p vector-app/src/main/assets
          echo '{ "defaultHomeserverUrl": "${{ env.HS_URL }}" }' > vector-app/src/main/assets/vector_config.json

      - name: Build release APK (optimized)
        run: |
          ./gradlew clean :vector-app:assembleFdroidRelease \
            -PminifyEnabled=true \
            -PshrinkResources=true \
            --no-daemon --stacktrace

      - name: List built APKs
        run: ls -lh vector-app/build/outputs/apk/**/release/

      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: fdroid-release
          path: vector-app/build/outputs/apk/**/release/*.apk
