name: APK (Fdroid arm64 only)

on:
  push:
  workflow_dispatch:

env:
  # سرور پیش‌فرض تو
  HS_URL: https://edu97.ir
  GRADLE_OPTS: -Dorg.gradle.jvmargs="-Xmx3072m -Dfile.encoding=UTF-8"
  CI_GRADLE_ARG_PROPERTIES: --stacktrace --max-workers 2 --no-daemon

jobs:
  build-fdroid-arm64:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Use JDK 21
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '21'

      - name: Configure Gradle cache
        uses: gradle/actions/setup-gradle@v3

      # تنظیم سرور پیش‌فرض داخل اپ
      - name: Set default homeserver
        run: |
          mkdir -p vector-app/src/main/assets
          cat > vector-app/src/main/assets/vector_config.json <<EOF
          { "defaultHomeserverUrl": "${HS_URL}" }
          EOF
          echo "vector_config.json created with HS_URL=${HS_URL}"

      # بیلد فقط Fdroid (سریع و سازگار)
      - name: Build APK (Fdroid Debug)
        run: ./gradlew :vector-app:assembleFdroidDebug $CI_GRADLE_ARG_PROPERTIES

      # فقط arm64-v8a آپلود می‌شود (Artifact کم‌حجم)
      - name: Upload APK (Fdroid arm64-v8a Debug)
        uses: actions/upload-artifact@v4
        with:
          name: fdroid-debug-arm64
          path: vector-app/build/outputs/apk/fdroid/debug/*arm64-v8a*.apk
          if-no-files-found: error
