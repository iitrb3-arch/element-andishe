name: Build APK (Fdroid - Simple)

on:
  workflow_dispatch:
  push:
    paths:
      - 'vector-app/**'
      - '.github/workflows/build-apk.yml'

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout project
        uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17

      - name: Install Android SDK
        uses: android-actions/setup-android@v3

      - name: Build APK (Fdroid Release)
        run: |
          chmod +x ./gradlew
          ./gradlew :vector-app:assembleFdroidRelease --no-daemon --stacktrace

      - name: List built APKs
        run: ls -R vector-app/build/outputs/apk || true

      - name: Upload APK artifact
        uses: actions/upload-artifact@v4
        with:
          name: Andishe-Release-APK
          path: |
            vector-app/build/outputs/apk/fdroid/release/*.apk
