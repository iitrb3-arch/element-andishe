name: Build F-Droid Release APK

on:
  workflow_dispatch:
  push:
    branches: [ develop ]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '17'

      - name: Setup Gradle
        uses: gradle/actions/setup-gradle@v3

      - name: Clean and build F-Droid release
        run: |
          ./gradlew clean :vector-app:assembleFdroidRelease \
            -PminifyEnabled=true -PshrinkResources=true --no-daemon --stacktrace

      - name: Upload APK artifact
        uses: actions/upload-artifact@v4
        with:
          name: fdroid-release
          path: vector-app/build/outputs/apk/fdroid/release/*.apk
